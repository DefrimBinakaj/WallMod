<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="WallMod.Views.SettingsView"
		xmlns:vm="using:WallMod.ViewModels"
		xmlns:views="using:WallMod.Views"
		xmlns:convs="using:WallMod.Converters"
		x:DataType="vm:SettingsViewModel">

	<Grid Margin="38">

		<Border Grid.RowSpan="2"
            Margin="-38"
            IsHitTestVisible="False"
            Opacity="0.01"
            Background="{Binding SelectedBackgroundColour, Converter={StaticResource ColorToBrushConverter}}"/>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<!-- Title + Back -->
			<RowDefinition Height="*"/>
			<!-- The tabs -->
		</Grid.RowDefinitions>

		<!-- Title + Back Button row=0 -->
		<Grid Grid.Row="0" Margin="0,0,0,40">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<Button Content="Back"
					Command="{Binding backButton}"
					Grid.Column="0"
					HorizontalAlignment="Left"
					VerticalAlignment="Center">
			</Button>

			<TextBlock Text="Settings"
					   FontSize="24"
					   FontWeight="Bold"
					   HorizontalAlignment="Center"
					   VerticalAlignment="Center"
					   Grid.Column="0"/>
		</Grid>


		<!-- tabs -->
		<TabControl Grid.Row="1">

			<!-- TAB 1: HISTORY -->
			<TabItem Header="History">

				<Grid HorizontalAlignment="Stretch">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="0.15*"/>
						<ColumnDefinition Width="0.7*"/>
						<ColumnDefinition Width="0.15*"/>
					</Grid.ColumnDefinitions>

					<StackPanel Grid.Column="1" Margin="0,30,0,20" Spacing="4">

						<!-- GROUP 1: History Settings -->
						<TextBlock Text="Wallpaper History"
								   Foreground="LightGray"
								   FontSize="16"
								   FontWeight="Bold"
								   Margin="0,32,0,8"/>
						<Border CornerRadius="12"
								Background="rgba(20, 20, 20, 200)"
								Padding="16">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="40"/>
									<RowDefinition Height="8"/>
									<RowDefinition Height="40"/>
								</Grid.RowDefinitions>
								<!-- Allow Save History -->
								<TextBlock Grid.Row="0" Grid.Column="0"
										   Text="Allow saving wallpapers to history:"
										   VerticalAlignment="Center"
										   Margin="12,0,0,0"
										   Foreground="White"/>
								<ToggleSwitch Grid.Row="0" Grid.Column="1"
											  IsChecked="{Binding AllowSaveHistory}"
											  HorizontalAlignment="Right"
											  VerticalAlignment="Center"/>
								<!-- Delete Entire History -->
								<TextBlock Grid.Row="2" Grid.Column="0"
										   Text="Delete entire wallpaper history:"
										   VerticalAlignment="Center"
										   Margin="12,0,0,0"
										   Foreground="White"/>
								<Button Grid.Row="2" Grid.Column="1"
										Content="🗑️"
										Command="{Binding deleteHistoryButton}"
										Background="DarkRed"
										HorizontalAlignment="Right"
										VerticalAlignment="Center"/>
							</Grid>
						</Border>

						<!-- GROUP 2: Startup Behavior -->
						<TextBlock Text="Startup"
								   Foreground="LightGray"
								   FontSize="16"
								   FontWeight="Bold"
								   Margin="0,32,0,8"/>
						<Border CornerRadius="12"
								Background="rgba(20, 20, 20, 200)"
								Padding="16">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="40"/>
									<RowDefinition Height="8"/>
									<RowDefinition Height="40"/>
								</Grid.RowDefinitions>
								<!-- Auto Open Last Directory -->
								<TextBlock Grid.Row="0" Grid.Column="0"
										   Text="Automatically open last directory on startup:"
										   VerticalAlignment="Center"
										   Margin="12,0,0,0"
										   Foreground="White"/>
								<ToggleSwitch Grid.Row="0" Grid.Column="1"
											  IsChecked="{Binding AutoOpenLastDirectory}"
											  HorizontalAlignment="Right"/>
								<!-- Remember Filters -->
								<TextBlock Grid.Row="2" Grid.Column="0"
										   Text="Remember filters on startup:"
										   VerticalAlignment="Center"
										   Margin="12,0,0,0"
										   Foreground="White"/>
								<ToggleSwitch Grid.Row="2" Grid.Column="1"
											  IsChecked="{Binding RememberFilters}"
											  HorizontalAlignment="Right"/>
							</Grid>

						</Border>
					</StackPanel>

				</Grid>
			</TabItem>

			<!-- TAB 2: THEME -->
			<TabItem Header="Theme">

				<Grid HorizontalAlignment="Stretch">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="0.15*"/>
						<ColumnDefinition Width="0.7*"/>
						<ColumnDefinition Width="0.15*"/>
					</Grid.ColumnDefinitions>

					<StackPanel Grid.Column="1" Margin="0,30,0,20" Spacing="4">
						<TextBlock Text="Colour / Theme"
								   Foreground="LightGray"
								   FontSize="16"
								   FontWeight="Bold"
								   Margin="0,32,0,8"/>
						<Border CornerRadius="12"
								Background="rgba(20, 20, 20, 200)"
								Padding="16">

							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<!-- Each row will auto-size -->
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="8"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="8"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="8"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<!-- Row 1: Background colour -->
								<TextBlock Grid.Row="0" Grid.Column="0"
										   Text="Background"
										   Foreground="White"
										   Margin="12,0,0,0"
										   VerticalAlignment="Center"/>
								<ColorPicker Grid.Row="0" Grid.Column="1"
											 Width="100" Height="40"
											 Color="{Binding SelectedBackgroundColour, Mode=TwoWay}"
											 IsAccentColorsVisible="True"
											 IsAlphaVisible="True"
											 IsAlphaEnabled="True"
											 VerticalAlignment="Center"/>

								<!-- Row 2: Primary accent colour -->
								<TextBlock Grid.Row="2" Grid.Column="0"
										   Text="Primary Accent"
										   Foreground="White"
										   Margin="12,0,0,0"
										   VerticalAlignment="Center"/>
								<ColorPicker Grid.Row="2" Grid.Column="1"
											 Width="100" Height="40"
											 Color="{Binding SelectedPrimaryAccentColour, Mode=TwoWay}"
											 IsAccentColorsVisible="True"
											 IsAlphaVisible="True"
											 IsAlphaEnabled="True"
											 VerticalAlignment="Center"/>

								<!-- Row 3: Wallpaper Collection colour -->
								<TextBlock Grid.Row="4" Grid.Column="0"
										   Text="Wallpaper Collection Background"
										   Foreground="White"
										   Margin="12,0,0,0"
										   VerticalAlignment="Center"/>
								<ColorPicker Grid.Row="4" Grid.Column="1"
											 Width="100" Height="40"
											 Color="{Binding SelectedWallpaperCollectionColour, Mode=TwoWay}"
											 IsAccentColorsVisible="True"
											 IsAlphaVisible="True"
											 IsAlphaEnabled="True"
											 VerticalAlignment="Center"/>

								<!-- Row 3: Preview Background colour -->
								<TextBlock Grid.Row="6" Grid.Column="0"
										   Text="Preview Background"
										   Foreground="White"
										   Margin="12,0,0,0"
										   VerticalAlignment="Center"/>
								<ColorPicker Grid.Row="6" Grid.Column="1"
											 Width="100" Height="40"
											 Color="{Binding SelectedPreviewBackgroundColour, Mode=TwoWay}"
											 IsAccentColorsVisible="True"
											 IsAlphaVisible="True"
											 IsAlphaEnabled="True"
											 VerticalAlignment="Center"/>



							</Grid>

						</Border>

						<!-- Mini-app theme preview *********** -->
						<TextBlock Text="(Preview)"
								   Foreground="LightGray"
								   FontSize="14"
								   FontWeight="Bold"
								   Margin="0,24,0,4"
								   HorizontalAlignment="Center"/>
						<!-- background -->
						<Border CornerRadius="12"
								Background="{Binding SelectedBackgroundColour, Converter={StaticResource ColorToBrushConverter}}"
								Padding="12"
								Width="350"
								Height="160">
							<Grid ColumnDefinitions="0.55*, Auto, 0.45*">
								<!-- left pane (wallpaper collection) -->
								<Border Grid.Column="0"
										CornerRadius="8"
										Background="{Binding SelectedWallpaperCollectionColour, Converter={StaticResource ColorToBrushConverter}}"/>
								<!-- middle splitter -->
								<Border Grid.Column="1"
										Width="6"
										CornerRadius="3"
										Margin="8,0"
										Background="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"/>
								<!-- preview pane with button overlaid on top -->
								<Grid Grid.Column="2">
									<Border CornerRadius="8"
											Background="{Binding SelectedPreviewBackgroundColour, Converter={StaticResource ColorToBrushConverter}}"/>
									<!-- "set wallpaper" button -->
									<Border CornerRadius="6"
											Height="26"
											Width="110"
											Margin="0,0,0,10"
											HorizontalAlignment="Center"
											VerticalAlignment="Bottom"
											Background="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"/>
								</Grid>
							</Grid>
						</Border>


					</StackPanel>
				</Grid>
			</TabItem>

			<!-- TAB 3: HOTKEYS -->
			<TabItem Header="Hotkeys">

				<Grid HorizontalAlignment="Stretch">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="0.15*"/>
						<ColumnDefinition Width="0.7*"/>
						<ColumnDefinition Width="0.15*"/>
					</Grid.ColumnDefinitions>

					<!-- SUBTITLE -->
					<StackPanel Grid.Column="1" Margin="0,30,0,20" Spacing="4">
						<TextBlock Text="Keyboard Hotkeys/Shortcuts"
								   Foreground="LightGray"
								   FontSize="16"
								   FontWeight="Bold"
								   Margin="0,32,0,8"/>

						<!-- main border -->
						<Border CornerRadius="12"
								Background="rgba(20, 20, 20, 200)"
								Padding="16">
							<StackPanel>


								<!-- slider +/- (=/-) -->
								<TextBlock Text="Image Thumbnail Zoom"
											Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"
											FontSize="15"
											Margin="0,0,0,10"/>
								<Grid ColumnDefinitions="Auto,*"
										ColumnSpacing="64"
										Margin="0,0,0,6">

									<!-- key group -->
									<Border Grid.Column="0"
											Background="rgba(45, 45, 45, 180)"
											CornerRadius="10"
											Padding="14,10"
											MinWidth="140"
											HorizontalAlignment="Left">
										<StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
											<Border Background="rgba(25, 25, 25, 220)"
													CornerRadius="8"
													Padding="16,8"
													MinWidth="56">
												<TextBlock Text="="
															Foreground="White"
															FontSize="28"
															FontWeight="Bold"
															HorizontalAlignment="Center"
															VerticalAlignment="Center"/>
											</Border>

											<Border Background="rgba(25, 25, 25, 220)"
													CornerRadius="8"
													Padding="16,8"
													MinWidth="56">
												<TextBlock Text="-"
															Foreground="White"
															FontSize="28"
															FontWeight="Bold"
															HorizontalAlignment="Center"
															VerticalAlignment="Center"/>
											</Border>
										</StackPanel>
									</Border>

									<TextBlock Grid.Column="1"
												Text="Increase / decrease thumbnail size in the image layout (+/-)"
												Foreground="LightGray"
												FontSize="15"
												VerticalAlignment="Center"/>
								</Grid>


								<!-- divider between sets -->
								<Border Height="1"
										Background="rgba(255,255,255,0.10)"
										Margin="0,18,0,18"/>


								<!-- Jump to top/bot -->
								<TextBlock Text="Jump to Top / Bottom"
											Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"
											FontSize="15"
											Margin="0,0,0,10"/>
								<Grid ColumnDefinitions="Auto,*"
										ColumnSpacing="64"
										Margin="0,0,0,6">

									<Border Grid.Column="0"
											Background="rgba(45, 45, 45, 180)"
											CornerRadius="10"
											Padding="14,10"
											MinWidth="140"
											HorizontalAlignment="Left">
										<StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
											<Border Background="rgba(25, 25, 25, 220)"
													CornerRadius="8"
													Padding="16,8"
													MinWidth="56">
												<TextBlock Text="g"
															Foreground="White"
															FontSize="28"
															FontWeight="Bold"
															HorizontalAlignment="Center"
															VerticalAlignment="Center"/>
											</Border>

											<Border Background="rgba(25, 25, 25, 220)"
													CornerRadius="8"
													Padding="16,8"
													MinWidth="56">
												<TextBlock Text="G"
															Foreground="White"
															FontSize="28"
															FontWeight="Bold"
															HorizontalAlignment="Center"
															VerticalAlignment="Center"/>
											</Border>
										</StackPanel>
									</Border>
									<TextBlock Grid.Column="1"
												Text="Jump to the top / bottom of the list of images"
												Foreground="LightGray"
												FontSize="15"
												VerticalAlignment="Center"/>
								</Grid>


								<!-- divider between sets -->
								<Border Height="1"
										Background="rgba(255,255,255,0.10)"
										Margin="0,18,0,18"/>


								<!-- Vert Splitter Shifting -->
								<TextBlock Text="Vertical Splitter Shifting"
											Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"
											FontSize="15"
											Margin="0,0,0,10"/>

								<Grid ColumnDefinitions="Auto,*"
										ColumnSpacing="64">

									<Border Grid.Column="0"
											Background="rgba(45, 45, 45, 180)"
											CornerRadius="10"
											Padding="14,10"
											MinWidth="140"
											HorizontalAlignment="Left">
										<StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
											<Border Background="rgba(25, 25, 25, 220)"
													CornerRadius="8"
													Padding="16,8"
													MinWidth="56">
												<TextBlock Text="["
															Foreground="White"
															FontSize="28"
															FontWeight="Bold"
															HorizontalAlignment="Center"
															VerticalAlignment="Center"/>
											</Border>

											<Border Background="rgba(25, 25, 25, 220)"
													CornerRadius="8"
													Padding="16,8"
													MinWidth="56">
												<TextBlock Text="]"
															Foreground="White"
															FontSize="28"
															FontWeight="Bold"
															HorizontalAlignment="Center"
															VerticalAlignment="Center"/>
											</Border>
										</StackPanel>
									</Border>

									<TextBlock Grid.Column="1"
												Text="Move the vertical splitter in the main layout left / right"
												Foreground="LightGray"
												FontSize="15"
												VerticalAlignment="Center"/>
								</Grid>

							</StackPanel>

						</Border>

					</StackPanel>

				</Grid>
			</TabItem>

			<!-- TAB 4: SYSTEM -->
			<TabItem Header="System">
				<Grid HorizontalAlignment="Stretch">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="0.15*"/>
						<ColumnDefinition Width="0.7*"/>
						<ColumnDefinition Width="0.15*"/>
					</Grid.ColumnDefinitions>

					<StackPanel Grid.Column="1" Margin="0,30,0,20" Spacing="4">

						<!-- AppName, Version & GitHub Row -->
						<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="0,30,0,0">
							<Image Source="avares://WallMod/Assets/wallmodicon.ico"
								   Width="35" Height="35"/>
							<TextBlock Text="WallMod  |"
									   Foreground="White"
									   FontWeight="Bold"
									   FontSize="28"
									   VerticalAlignment="Center"/>
							<TextBlock Text="{Binding AppNameVersion}"
									   Foreground="LightGray"
									   FontWeight="Bold"
									   FontSize="22"
									   VerticalAlignment="Center"
									   Margin="0,2,0,0"/>
							<Button Command="{Binding openGithubButton}"
									Background="Transparent"
									BorderThickness="0"
									Margin="0,0,0,0">
								<Image Source="avares://WallMod/Assets/github-logo.png"
									   Width="30" Height="35"/>
							</Button>

							<Button Content="Update Available!"
									Command="{Binding updateAppButton}"
									Background="Transparent"
									BorderThickness="0"
									Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"
									FontSize="18"
									FontWeight="Bold"
									IsVisible="{Binding UpdateAvailableVisible}"/>

						</StackPanel>

						<!-- GROUP: System Settings -->
						<TextBlock Text="System Settings"
								   Foreground="LightGray"
								   FontSize="16"
								   FontWeight="Bold"
								   Margin="0,32,0,8"/>
						<Border CornerRadius="12"
								Background="rgba(20, 20, 20, 200)"
								Padding="16">

							<StackPanel>
								<!-- Stay Running in Background -->
								<StackPanel Orientation="Horizontal" Spacing="8" Margin="12,0,0,12">
									<TextBlock Text="Stay Running in Background:"
											   VerticalAlignment="Center"
											   Foreground="White"
											   FontSize="14"/>
									<ToggleSwitch IsChecked="{Binding StayRunningInBackground}"
												  HorizontalAlignment="Right"/>
								</StackPanel>
								<!-- CPU Threads allocated -->
								<TextBlock Text="CPU Threads allocated"
										   Foreground="White"
										   FontSize="14"
										   Margin="12,12,0,0"/>
								<TextBlock Text="used only for image processing ( >85% recommended)"
										   Foreground="Gray"
										   FontSize="12"
										   Margin="12,12,0,4"/>
								<StackPanel Orientation="Horizontal" Spacing="16" Margin="12,0,0,12">
									<Slider Minimum="1"
											Maximum="{Binding MaxCPUThreads}"
											TickFrequency="1"
											IsSnapToTickEnabled="True"
											Value="{Binding CPUThreadsAllocated}"
											Background="Gray"
											Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"
											Width="300"/>
									<TextBlock Text="{Binding CPUThreadsAllocated}"
											   VerticalAlignment="Center"
											   FontSize="18"
											   Foreground="White"/>
								</StackPanel>
								<Button Content="Browse Crash Logs and System Storage Files" Margin="12,0,0,12"
										Background="rgba(106, 0, 0, 1)"
										Command="{Binding OpenStorageFiles}"/>
							</StackPanel>
						</Border>
					</StackPanel>
				</Grid>
			</TabItem>



		</TabControl>

		<TextBlock Grid.Row="1"
           Text="⚠"
           FontSize="22"
           FontWeight="Bold"
           HorizontalAlignment="Left"
           VerticalAlignment="Top"
           Margin="423,11,0,0"
           IsVisible="{Binding UpdateAvailableVisible}"
           Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"
           ToolTip.Tip="Update available"/>


	</Grid>
	
</UserControl>
