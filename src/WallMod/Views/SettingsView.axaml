<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="WallMod.Views.SettingsView"
		xmlns:vm="using:WallMod.ViewModels"
		xmlns:views="using:WallMod.Views"
		xmlns:convs="using:WallMod.Converters"
		x:DataType="vm:SettingsViewModel">

	<Grid Margin="38">

		<Border Grid.RowSpan="2"
            Margin="-38"
            IsHitTestVisible="False"
            Opacity="0.01"
            Background="{Binding SelectedBackgroundColour, Converter={StaticResource ColorToBrushConverter}}"/>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<!-- Title + Back -->
			<RowDefinition Height="*"/>
			<!-- The tabs -->
		</Grid.RowDefinitions>

		<!-- Title + Back Button row=0 -->
		<Grid Grid.Row="0" Margin="0,0,0,40">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<Button Content="Back"
					Command="{Binding backButton}"
					Grid.Column="0"
					HorizontalAlignment="Left"
					VerticalAlignment="Center">
			</Button>

			<TextBlock Text="Settings"
					   FontSize="24"
					   FontWeight="Bold"
					   HorizontalAlignment="Center"
					   VerticalAlignment="Center"
					   Grid.Column="0"/>
		</Grid>


		<!-- tabs -->
		<TabControl Grid.Row="1">

			<!-- TAB 1: HISTORY -->
			<TabItem Header="History">

				<Grid HorizontalAlignment="Stretch">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="0.15*"/>
						<ColumnDefinition Width="0.7*"/>
						<ColumnDefinition Width="0.15*"/>
					</Grid.ColumnDefinitions>

					<StackPanel Grid.Column="1" Margin="0,30,0,20" Spacing="4">

						<!-- GROUP 1: History Settings -->
						<TextBlock Text="Wallpaper History"
								   Foreground="LightGray"
								   FontSize="16"
								   FontWeight="Bold"
								   Margin="0,32,0,8"/>
						<Border CornerRadius="12"
								Background="rgba(20, 20, 20, 200)"
								Padding="16">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="40"/>
									<RowDefinition Height="8"/>
									<RowDefinition Height="40"/>
								</Grid.RowDefinitions>
								<!-- Allow Save History -->
								<TextBlock Grid.Row="0" Grid.Column="0"
										   Text="Allow saving wallpapers to history:"
										   VerticalAlignment="Center"
										   Margin="12,0,0,0"
										   Foreground="White"/>
								<ToggleSwitch Grid.Row="0" Grid.Column="1"
											  IsChecked="{Binding AllowSaveHistory}"
											  HorizontalAlignment="Right"
											  VerticalAlignment="Center"/>
								<!-- Delete Entire History -->
								<TextBlock Grid.Row="2" Grid.Column="0"
										   Text="Delete entire wallpaper history:"
										   VerticalAlignment="Center"
										   Margin="12,0,0,0"
										   Foreground="White"/>
								<Button Grid.Row="2" Grid.Column="1"
										Content="🗑️"
										Command="{Binding deleteHistoryButton}"
										Background="DarkRed"
										HorizontalAlignment="Right"
										VerticalAlignment="Center"/>
							</Grid>
						</Border>

						<!-- GROUP 2: Startup Behavior -->
						<TextBlock Text="Startup"
								   Foreground="LightGray"
								   FontSize="16"
								   FontWeight="Bold"
								   Margin="0,32,0,8"/>
						<Border CornerRadius="12"
								Background="rgba(20, 20, 20, 200)"
								Padding="16">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="40"/>
									<RowDefinition Height="8"/>
									<RowDefinition Height="40"/>
								</Grid.RowDefinitions>
								<!-- Auto Open Last Directory -->
								<TextBlock Grid.Row="0" Grid.Column="0"
										   Text="Automatically open last directory on startup:"
										   VerticalAlignment="Center"
										   Margin="12,0,0,0"
										   Foreground="White"/>
								<ToggleSwitch Grid.Row="0" Grid.Column="1"
											  IsChecked="{Binding AutoOpenLastDirectory}"
											  HorizontalAlignment="Right"/>
								<!-- Remember Filters -->
								<TextBlock Grid.Row="2" Grid.Column="0"
										   Text="Remember filters on startup:"
										   VerticalAlignment="Center"
										   Margin="12,0,0,0"
										   Foreground="White"/>
								<ToggleSwitch Grid.Row="2" Grid.Column="1"
											  IsChecked="{Binding RememberFilters}"
											  HorizontalAlignment="Right"/>
							</Grid>

						</Border>
					</StackPanel>

				</Grid>
			</TabItem>

			<!-- TAB 2: THEME -->
			<TabItem Header="Theme">

				<Grid HorizontalAlignment="Stretch">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="0.15*"/>
						<ColumnDefinition Width="0.7*"/>
						<ColumnDefinition Width="0.15*"/>
					</Grid.ColumnDefinitions>

					<StackPanel Grid.Column="1" Margin="0,30,0,20" Spacing="4">
						<TextBlock Text="Colour / Theme"
								   Foreground="LightGray"
								   FontSize="16"
								   FontWeight="Bold"
								   Margin="0,32,0,8"/>
						<Border CornerRadius="12"
								Background="rgba(20, 20, 20, 200)"
								Padding="16">

							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<!-- Each row will auto-size -->
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="8"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="8"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="8"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<!-- Row 1: Background colour -->
								<TextBlock Grid.Row="0" Grid.Column="0"
										   Text="Background"
										   Foreground="White"
										   Margin="12,0,0,0"
										   VerticalAlignment="Center"/>
								<ColorPicker Grid.Row="0" Grid.Column="1"
											 Width="100" Height="40"
											 Color="{Binding SelectedBackgroundColour, Mode=TwoWay}"
											 IsAccentColorsVisible="True"
											 IsAlphaVisible="True"
											 IsAlphaEnabled="True"
											 VerticalAlignment="Center"/>

								<!-- Row 2: Primary accent colour -->
								<TextBlock Grid.Row="2" Grid.Column="0"
										   Text="Primary Accent"
										   Foreground="White"
										   Margin="12,0,0,0"
										   VerticalAlignment="Center"/>
								<ColorPicker Grid.Row="2" Grid.Column="1"
											 Width="100" Height="40"
											 Color="{Binding SelectedPrimaryAccentColour, Mode=TwoWay}"
											 IsAccentColorsVisible="True"
											 IsAlphaVisible="True"
											 IsAlphaEnabled="True"
											 VerticalAlignment="Center"/>

								<!-- Row 3: Wallpaper Collection colour -->
								<TextBlock Grid.Row="4" Grid.Column="0"
										   Text="Wallpaper Collection Background"
										   Foreground="White"
										   Margin="12,0,0,0"
										   VerticalAlignment="Center"/>
								<ColorPicker Grid.Row="4" Grid.Column="1"
											 Width="100" Height="40"
											 Color="{Binding SelectedWallpaperCollectionColour, Mode=TwoWay}"
											 IsAccentColorsVisible="True"
											 IsAlphaVisible="True"
											 IsAlphaEnabled="True"
											 VerticalAlignment="Center"/>

								<!-- Row 3: Preview Background colour -->
								<TextBlock Grid.Row="6" Grid.Column="0"
										   Text="Preview Background"
										   Foreground="White"
										   Margin="12,0,0,0"
										   VerticalAlignment="Center"/>
								<ColorPicker Grid.Row="6" Grid.Column="1"
											 Width="100" Height="40"
											 Color="{Binding SelectedPreviewBackgroundColour, Mode=TwoWay}"
											 IsAccentColorsVisible="True"
											 IsAlphaVisible="True"
											 IsAlphaEnabled="True"
											 VerticalAlignment="Center"/>



							</Grid>

						</Border>

						<!-- Mini-app theme preview *********** -->
						<TextBlock Text="(Preview)"
								   Foreground="LightGray"
								   FontSize="14"
								   FontWeight="Bold"
								   Margin="0,24,0,4"
								   HorizontalAlignment="Center"/>
						<!-- background -->
						<Border CornerRadius="12"
								Background="{Binding SelectedBackgroundColour, Converter={StaticResource ColorToBrushConverter}}"
								Padding="12"
								Width="350"
								Height="160">
							<Grid ColumnDefinitions="0.55*, Auto, 0.45*">
								<!-- left pane (wallpaper collection) -->
								<Border Grid.Column="0"
										CornerRadius="8"
										Background="{Binding SelectedWallpaperCollectionColour, Converter={StaticResource ColorToBrushConverter}}"/>
								<!-- middle splitter -->
								<Border Grid.Column="1"
										Width="6"
										CornerRadius="3"
										Margin="8,0"
										Background="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"/>
								<!-- preview pane with button overlaid on top -->
								<Grid Grid.Column="2">
									<Border CornerRadius="8"
											Background="{Binding SelectedPreviewBackgroundColour, Converter={StaticResource ColorToBrushConverter}}"/>
									<!-- "set wallpaper" button -->
									<Border CornerRadius="6"
											Height="26"
											Width="110"
											Margin="0,0,0,10"
											HorizontalAlignment="Center"
											VerticalAlignment="Bottom"
											Background="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"/>
								</Grid>
							</Grid>
						</Border>


					</StackPanel>
				</Grid>
			</TabItem>

			<!-- TAB 3: HOTKEYS -->
			<TabItem Header="Hotkeys">

				<Grid ColumnDefinitions="0.55*,0.45*" Margin="30,10,30,20">

					<!-- ====================== LEFT HALF: ALL KEYBOARD HOTKEYS ====================== -->
					<ScrollViewer Grid.Column="0" Margin="0,0,12,0" VerticalScrollBarVisibility="Auto">
						<StackPanel Spacing="10">

							<TextBlock Classes="hkPageTitle" Text="Keyboard Hotkeys"/>

							<!-- Gallery Navigation -->
							<Border Classes="hkCard">
								<StackPanel Spacing="3">
									<TextBlock Classes="hkSection" Text="Gallery Navigation"
											   Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"/>

									<Grid Classes="hkRow" ColumnDefinitions="185,*">
										<StackPanel Orientation="Horizontal" Spacing="5">
											<Border Classes="keycap">
												<TextBlock Text="← ↑ ↓ →"/>
											</Border>
											<Border Classes="keycap">
												<TextBlock Text="hjkl"/>
											</Border>
										</StackPanel>
										<TextBlock Grid.Column="1" Classes="hkDesc" Text="Move the selection through the image gallery"/>
									</Grid>

									<Grid Classes="hkRow" ColumnDefinitions="185,*">
										<StackPanel Orientation="Horizontal" Spacing="5">
											<Border Classes="keycap">
												<TextBlock Text="Enter"/>
											</Border>
										</StackPanel>
										<TextBlock Grid.Column="1" Classes="hkDesc" Text="Enter the selected item (folder)"/>
									</Grid>

									<Grid Classes="hkRow" ColumnDefinitions="185,*">
										<StackPanel Orientation="Horizontal" Spacing="5">
											<Border Classes="keycap">
												<TextBlock Text="g"/>
											</Border>
											<Border Classes="keycap">
												<TextBlock Text="G"/>
											</Border>
										</StackPanel>
										<TextBlock Grid.Column="1" Classes="hkDesc" Text="Jump to the top / bottom of the image gallery"/>
									</Grid>

									<Grid Classes="hkRow" ColumnDefinitions="185,*">
										<StackPanel Orientation="Horizontal" Spacing="5">
											<Border Classes="keycap">
												<TextBlock Text="Backspace"/>
											</Border>
										</StackPanel>
										<TextBlock Grid.Column="1" Classes="hkDesc" Text="Navigate to the parent directory"/>
									</Grid>

									<Grid Classes="hkRow" ColumnDefinitions="185,*">
										<StackPanel Orientation="Horizontal" Spacing="5">
											<Border Classes="keycap">
												<TextBlock Text="="/>
											</Border>
											<Border Classes="keycap">
												<TextBlock Text="-"/>
											</Border>
										</StackPanel>
										<TextBlock Grid.Column="1" Classes="hkDesc" Text="Increase / decrease thumbnail size (+/-)"/>
									</Grid>
								</StackPanel>
							</Border>

							<!-- Image Actions -->
							<Border Classes="hkCard">
								<StackPanel Spacing="3">
									<TextBlock Classes="hkSection" Text="Image Actions"
											   Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"/>

									<Grid Classes="hkRow" ColumnDefinitions="185,*">
										<StackPanel Orientation="Horizontal" Spacing="5">
											<Border Classes="keycap">
												<TextBlock Text="B"/>
											</Border>
										</StackPanel>
										<TextBlock Grid.Column="1" Classes="hkDesc" Text="Set the previewed image as background (when a monitor is selected)"/>
									</Grid>

									<Grid Classes="hkRow" ColumnDefinitions="185,*">
										<StackPanel Orientation="Horizontal" Spacing="5">
											<Border Classes="keycap">
												<TextBlock Text="Q"/>
											</Border>
										</StackPanel>
										<TextBlock Grid.Column="1" Classes="hkDesc" Text="Add selected image to custom autoset queue"/>
									</Grid>

									<Grid Classes="hkRow" ColumnDefinitions="185,*">
										<StackPanel Orientation="Horizontal" Spacing="5">
											<Border Classes="keycap">
												<TextBlock Text="F"/>
											</Border>
										</StackPanel>
										<TextBlock Grid.Column="1" Classes="hkDesc" Text="Toggle favourite for a selected image"/>
									</Grid>

									<Grid Classes="hkRow" ColumnDefinitions="185,*">
										<StackPanel Orientation="Horizontal" Spacing="5">
											<Border Classes="keycap">
												<TextBlock Text="O"/>
											</Border>
										</StackPanel>
										<TextBlock Grid.Column="1" Classes="hkDesc" Text="Open selected image in file explorer"/>
									</Grid>
								</StackPanel>
							</Border>

							<!-- Views & Menus -->
							<Border Classes="hkCard">
								<StackPanel Spacing="3">
									<TextBlock Classes="hkSection" Text="Views &amp; Menus"
											   Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"/>

									<Grid Classes="hkRow" ColumnDefinitions="185,*">
										<StackPanel Orientation="Horizontal" Spacing="5">
											<Border Classes="keycap">
												<TextBlock Text="Shift + F"/>
											</Border>
										</StackPanel>
										<TextBlock Grid.Column="1" Classes="hkDesc" Text="View filters"/>
									</Grid>

									<Grid Classes="hkRow" ColumnDefinitions="185,*">
										<StackPanel Orientation="Horizontal" Spacing="5">
											<Border Classes="keycap">
												<TextBlock Text="Shift + S"/>
											</Border>
										</StackPanel>
										<TextBlock Grid.Column="1" Classes="hkDesc" Text="View settings"/>
									</Grid>

									<Grid Classes="hkRow" ColumnDefinitions="185,*">
										<StackPanel Orientation="Horizontal" Spacing="5">
											<Border Classes="keycap">
												<TextBlock Text="Shift + A"/>
											</Border>
										</StackPanel>
										<TextBlock Grid.Column="1" Classes="hkDesc" Text="View Autoset"/>
									</Grid>

									<Grid Classes="hkRow" ColumnDefinitions="185,*">
										<StackPanel Orientation="Horizontal" Spacing="5">
											<Border Classes="keycap">
												<TextBlock Text="Shift + H"/>
											</Border>
										</StackPanel>
										<TextBlock Grid.Column="1" Classes="hkDesc" Text="Toggle wallpaper history view"/>
									</Grid>

									<Grid Classes="hkRow" ColumnDefinitions="185,*">
										<StackPanel Orientation="Horizontal" Spacing="5">
											<Border Classes="keycap">
												<TextBlock Text="Ctrl + F"/>
											</Border>
										</StackPanel>
										<TextBlock Grid.Column="1" Classes="hkDesc" Text="View your favourites collection"/>
									</Grid>

									<Grid Classes="hkRow" ColumnDefinitions="185,*">
										<StackPanel Orientation="Horizontal" Spacing="5">
											<Border Classes="keycap">
												<TextBlock Text="Esc"/>
											</Border>
										</StackPanel>
										<TextBlock Grid.Column="1" Classes="hkDesc" Text="Exit current view"/>
									</Grid>
								</StackPanel>
							</Border>

							<!-- Monitors -->
							<Border Classes="hkCard">
								<StackPanel Spacing="3">
									<TextBlock Classes="hkSection" Text="Monitors"
											   Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"/>

									<Grid Classes="hkRow" ColumnDefinitions="185,*">
										<StackPanel Orientation="Horizontal" Spacing="5">
											<Border Classes="keycap">
												<TextBlock Text="1"/>
											</Border>
											<Border Classes="keycap">
												<TextBlock Text="2"/>
											</Border>
											<Border Classes="keycap">
												<TextBlock Text="3"/>
											</Border>
											<Border Classes="keycap">
												<TextBlock Text="4"/>
											</Border>
										</StackPanel>
										<TextBlock Grid.Column="1" Classes="hkDesc" Text="Select monitor 1–4"/>
									</Grid>

									<Grid Classes="hkRow" ColumnDefinitions="185,*">
										<StackPanel Orientation="Horizontal" Spacing="5">
											<Border Classes="keycap">
												<TextBlock Text="M"/>
											</Border>
										</StackPanel>
										<TextBlock Grid.Column="1" Classes="hkDesc" Text="Toggle between One and All monitor mode"/>
									</Grid>

									<Grid Classes="hkRow" ColumnDefinitions="185,*">
										<StackPanel Orientation="Horizontal" Spacing="5">
											<Border Classes="keycap">
												<TextBlock Text="R"/>
											</Border>
										</StackPanel>
										<TextBlock Grid.Column="1" Classes="hkDesc" Text="Re-detect monitors"/>
									</Grid>
								</StackPanel>
							</Border>

							<!-- Layout -->
							<Border Classes="hkCard">
								<StackPanel Spacing="3">
									<TextBlock Classes="hkSection" Text="Layout"
											   Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"/>

									<Grid Classes="hkRow" ColumnDefinitions="185,*">
										<StackPanel Orientation="Horizontal" Spacing="5">
											<Border Classes="keycap">
												<TextBlock Text="["/>
											</Border>
											<Border Classes="keycap">
												<TextBlock Text="]"/>
											</Border>
										</StackPanel>
										<TextBlock Grid.Column="1" Classes="hkDesc" Text="Move the vertical splitter in the main layout left / right"/>
									</Grid>
								</StackPanel>
							</Border>

						</StackPanel>
					</ScrollViewer>


					<!-- ====================== RIGHT HALF: Tips & Tricks ====================== -->
					<ScrollViewer Grid.Column="1" Margin="12,0,0,0" VerticalScrollBarVisibility="Auto">
						<StackPanel Spacing="10">

							<TextBlock Classes="hkPageTitle" Text="Tips &amp; Tricks"/>

							<!-- Gallery -->
							<Border Classes="hkCard">
								<StackPanel Spacing="3">
									<TextBlock Classes="hkSection" Text="Gallery"
											   Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"/>

									<StackPanel Classes="hfRow">
										<TextBlock Classes="hfName" Text="Scroll to zoom"/>
										<TextBlock Classes="hfDesc" Text="Hover over the zoom slider and scroll the mouse wheel to resize thumbnails."/>
									</StackPanel>

									<StackPanel Classes="hfRow">
										<TextBlock Classes="hfName" Text="Folder navigation"/>
										<TextBlock Classes="hfDesc" Text="Double-click a folder to enter it. Backspace or the back button goes back to its parent."/>
									</StackPanel>

								</StackPanel>
							</Border>

							<!-- Preview & Cropping -->
							<Border Classes="hkCard">
								<StackPanel Spacing="3">
									<TextBlock Classes="hkSection" Text="Preview &amp; Cropping"
											   Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"/>

									<StackPanel Classes="hfRow">
										<TextBlock Classes="hfName" Text="Pick a monitor"/>
										<TextBlock Classes="hfDesc" Text="Click a monitor rectangle under the preview to target only that display."/>
									</StackPanel>

									<StackPanel Classes="hfRow">
										<TextBlock Classes="hfName" Text="Drag to crop"/>
										<TextBlock Classes="hfDesc" Text="Drag the gradient rectangle over the preview to choose which part of the image is used."/>
									</StackPanel>

									<StackPanel Classes="hfRow">
										<TextBlock Classes="hfName" Text="Resize the crop"/>
										<TextBlock Classes="hfDesc" Text="Drag the bottom-right corner of the rectangle to resize it while keeping aspect ratio."/>
									</StackPanel>

								</StackPanel>
							</Border>

							<!-- AutoSet Queue -->
							<Border Classes="hkCard">
								<StackPanel Spacing="3">
									<TextBlock Classes="hkSection" Text="AutoSet Queue"
											   Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"/>

									<StackPanel Classes="hfRow">
										<TextBlock Classes="hfName" Text="Reorder by dragging"/>
										<TextBlock Classes="hfDesc" Text="Drag images inside the custom queue to change the order they'll be set in."/>
									</StackPanel>

									<StackPanel Classes="hfRow">
										<TextBlock Classes="hfName" Text="Delete from queue"/>
										<TextBlock Classes="hfDesc" Text="Select an image in the custom queue and press DEL to remove it."/>
									</StackPanel>

								</StackPanel>
							</Border>

						</StackPanel>
					</ScrollViewer>

				</Grid>
				
			</TabItem>

			<!-- TAB 4: SYSTEM -->
			<TabItem Header="System">
				<Grid HorizontalAlignment="Stretch">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="0.15*"/>
						<ColumnDefinition Width="0.7*"/>
						<ColumnDefinition Width="0.15*"/>
					</Grid.ColumnDefinitions>

					<StackPanel Grid.Column="1" Margin="0,30,0,20" Spacing="4">

						<!-- AppName, Version & GitHub Row -->
						<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="0,30,0,0">
							<Image Source="avares://WallMod/Assets/wallmodicon.ico"
								   Width="35" Height="35"/>
							<TextBlock Text="WallMod  |"
									   Foreground="White"
									   FontWeight="Bold"
									   FontSize="28"
									   VerticalAlignment="Center"/>
							<TextBlock Text="{Binding AppNameVersion}"
									   Foreground="LightGray"
									   FontWeight="Bold"
									   FontSize="22"
									   VerticalAlignment="Center"
									   Margin="0,2,0,0"/>
							<Button Command="{Binding openGithubButton}"
									Background="Transparent"
									BorderThickness="0"
									Margin="0,0,0,0">
								<Image Source="avares://WallMod/Assets/github-logo.png"
									   Width="30" Height="35"/>
							</Button>

							<Button Content="Update Available!"
									Command="{Binding updateAppButton}"
									Background="Transparent"
									BorderThickness="0"
									Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"
									FontSize="18"
									FontWeight="Bold"
									IsVisible="{Binding UpdateAvailableVisible}"/>

						</StackPanel>

						<!-- GROUP: System Settings -->
						<TextBlock Text="System Settings"
								   Foreground="LightGray"
								   FontSize="16"
								   FontWeight="Bold"
								   Margin="0,32,0,8"/>
						<Border CornerRadius="12"
								Background="rgba(20, 20, 20, 200)"
								Padding="16">

							<StackPanel>
								<!-- Stay Running in Background -->
								<StackPanel Orientation="Horizontal" Spacing="8" Margin="12,0,0,12">
									<TextBlock Text="Stay Running in Background:"
											   VerticalAlignment="Center"
											   Foreground="White"
											   FontSize="14"/>
									<ToggleSwitch IsChecked="{Binding StayRunningInBackground}"
												  HorizontalAlignment="Right"/>
								</StackPanel>
								<!-- CPU Threads allocated -->
								<TextBlock Text="CPU Threads allocated"
										   Foreground="White"
										   FontSize="14"
										   Margin="12,12,0,0"/>
								<TextBlock Text="used only for image processing ( >85% recommended)"
										   Foreground="Gray"
										   FontSize="12"
										   Margin="12,12,0,4"/>
								<StackPanel Orientation="Horizontal" Spacing="16" Margin="12,0,0,12">
									<Slider Minimum="1"
											Maximum="{Binding MaxCPUThreads}"
											TickFrequency="1"
											IsSnapToTickEnabled="True"
											Value="{Binding CPUThreadsAllocated}"
											Background="Gray"
											Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"
											Width="300"/>
									<TextBlock Text="{Binding CPUThreadsAllocated}"
											   VerticalAlignment="Center"
											   FontSize="18"
											   Foreground="White"/>
								</StackPanel>
								<Button Content="Browse Crash Logs and System Storage Files" Margin="12,0,0,12"
										Background="rgba(106, 0, 0, 1)"
										Command="{Binding OpenStorageFiles}"/>
							</StackPanel>
						</Border>
					</StackPanel>
				</Grid>
			</TabItem>



		</TabControl>

		<TextBlock Grid.Row="1"
           Text="⚠"
           FontSize="22"
           FontWeight="Bold"
           HorizontalAlignment="Left"
           VerticalAlignment="Top"
           Margin="423,11,0,0"
           IsVisible="{Binding UpdateAvailableVisible}"
           Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"
           ToolTip.Tip="Update available"/>


	</Grid>
	
</UserControl>
