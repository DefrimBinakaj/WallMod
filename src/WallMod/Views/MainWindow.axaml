<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WallMod.ViewModels"
        xmlns:convs="using:WallMod.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ia="using:Xaml.Behaviors.Interactions.Animated"
        xmlns:views="using:WallMod.Views"
        WindowStartupLocation="CenterScreen"
        Width="1500"
        Height="750"
        MinWidth="700"
        MinHeight="300"
        x:Class="WallMod.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/wallmodicon.ico"
        Title="WallMod"
        Name="MainWindowAxaml"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True">

	<Design.DataContext>
		<vm:MainWindowViewModel/>
	</Design.DataContext>

	<Window.KeyBindings>
		<!-- selection actions -->
		<KeyBinding Command="{Binding addWallpaperToAutoSetCommand}"			Gesture="Q"/>
		<KeyBinding Command="{Binding addWallpaperToFavouritesCommand}"			Gesture="F"/>
		<KeyBinding Command="{Binding #MainWindowAxaml.HotkeySetBackground}"    Gesture="B"/>
		<KeyBinding Command="{Binding openImageInExplorerCommand}"				Gesture="O"/>
		<!-- views / menus -->
		<KeyBinding Command="{Binding autoSetNavCommand}"						Gesture="Shift+A"/>
		<KeyBinding Command="{Binding viewHistoryButton}"						Gesture="Shift+H"/>
		<KeyBinding Command="{Binding viewFavouritesButton}"					Gesture="Shift+F"/>
		<KeyBinding Command="{Binding #MainWindowAxaml.HotkeyEscape}"           Gesture="Escape"/>
		<KeyBinding Command="{Binding settingsButton}"							Gesture="Shift+S" />
		<KeyBinding Command="{Binding filterClicked}"							Gesture="Ctrl+F" />
		<!-- monitors -->
		<KeyBinding Command="{Binding #MainWindowAxaml.HotkeyToggleMonitorMode}"	Gesture="M"/>
		<KeyBinding Command="{Binding #MainWindowAxaml.DetectMonitors}"   Gesture="R"/>
		<KeyBinding Command="{Binding #MainWindowAxaml.HotkeySelectMonitor}" CommandParameter="1" Gesture="D1"/>
		<KeyBinding Command="{Binding #MainWindowAxaml.HotkeySelectMonitor}" CommandParameter="2" Gesture="D2"/>
		<KeyBinding Command="{Binding #MainWindowAxaml.HotkeySelectMonitor}" CommandParameter="3" Gesture="D3"/>
		<KeyBinding Command="{Binding #MainWindowAxaml.HotkeySelectMonitor}" CommandParameter="4" Gesture="D4"/>
		<!-- thumbnailzoom  -->
		<KeyBinding Command="{Binding HotkeyPlusClicked}"						 Gesture="OemPlus" />
		<KeyBinding Command="{Binding HotkeyMinusClicked}"						 Gesture="OemMinus" />
		<!-- vertical slider shifting -->
		<KeyBinding Command="{Binding #MainWindowAxaml.HotkeySqBraceLeft}"		 Gesture="OemOpenBrackets" />
		<KeyBinding Command="{Binding #MainWindowAxaml.HotkeySqBraceRight}"		 Gesture="OemCloseBrackets" />
		<!-- jumping to top / bottom -->
		<KeyBinding Command="{Binding #MainWindowAxaml.HotkeyG}"				 Gesture="G" />
		<KeyBinding Command="{Binding #MainWindowAxaml.HotkeyShiftG}"			 Gesture="Shift+G" />
		<!-- Backspace for navigating to parent directory (back) -->
		<KeyBinding Command="{Binding navigateToParentDirec}"					 Gesture="Back" />
		
	</Window.KeyBindings>

	<Panel>
		<ExperimentalAcrylicBorder IsHitTestVisible="False">
			<ExperimentalAcrylicBorder.Material>
				<ExperimentalAcrylicMaterial
					BackgroundSource="Digger"
					TintColor="{Binding SelectedBackgroundColour}"
					TintOpacity="0.4"
					MaterialOpacity="0.3" />
			</ExperimentalAcrylicBorder.Material>
		</ExperimentalAcrylicBorder>

		<Image Source="avares://Wallmod/Assets/wallmodicon.ico"
			   Width="18" Height="18"
			   HorizontalAlignment="Left" VerticalAlignment="Top"
			   Margin="8,8,0,0"
			   IsHitTestVisible="False"/>

		<Grid Margin="24" x:Name="MainGrid" IsVisible="{Binding MainGridVisibility}">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="2*" MinWidth="280"/>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" MinWidth="350"/>
			</Grid.ColumnDefinitions>

			<!-- bottom row for full-width AutoSet tray -->
			<Grid.RowDefinitions>
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

			<!-- Left Pane: Image Gallery and Controls & History ========= -->
			<Border Grid.Column="0" Grid.Row="0" Background="{Binding SelectedWallpaperCollectionColour, Converter={StaticResource ColorToBrushConverter}}" CornerRadius="10" Margin="8">
				<Panel>

					<!-- Image Gallery Section -->
					<Grid IsVisible="{Binding IsImageGalleryViewVisible}">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*" />
						</Grid.RowDefinitions>

						<ProgressBar Grid.Row="0" Minimum="0" Maximum="100" Value="{Binding ImgLoadProgress}" Height="15" Background="Gray" Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}" VerticalAlignment="Top" CornerRadius="10,0"/>

						<Button x:Name="FilterButton" Grid.Row="1" Command="{Binding filterClicked}" Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0, 6, 4, 0" ToolTip.Tip="Filter By">
							<Image Source="avares://Wallmod/Assets/filtericon.png" Width="17" Height="17"></Image>
						</Button>

						<Popup x:Name="FilterPopup"
							   PlacementTarget="{Binding #FilterButton}"
							   Placement="BottomEdgeAlignedRight"
							   IsLightDismissEnabled="True"
							   IsOpen="{Binding IsFilterOpen}">

							<!-- Filter Popup -->
							<Border Background="rgba(20, 20, 20, 20)"
									CornerRadius="5"
									Padding="10"
									MinWidth="200">
								<StackPanel Spacing="8">

									<!-- Title -->
									<TextBlock Text="Filter by:"
											   Foreground="White"
											   FontWeight="Bold" />

									<!-- Search bar -->
									<StackPanel Orientation="Horizontal" Spacing="4">
										<TextBox x:Name="FilterSearchBox"
												 Text="{Binding FilterSearchText}"
												 Width="180"
												 Watermark="Search..."
												 Foreground="White"
												 Background="rgba(52, 52, 52, 1)"/>
									</StackPanel>

									<!-- Folder Filter -->
									<CheckBox Content="Show Folders"
											  Foreground="White"
											  Margin="0,8,0,0"
											  IsChecked="{Binding ShowFolders}"/>

									<!-- Image Property -->
									<StackPanel Orientation="Vertical" Spacing="4">
										<RadioButton Content="Name"
													 GroupName="FilterGroup"
													 Command="{Binding filterGroupSelectedCommand}"
													 CommandParameter="Name"
													 IsChecked="{Binding CurrentSortChoice, Mode=TwoWay, Converter={StaticResource BoolToStrConverter}, ConverterParameter=Name}"
													 Foreground="White"/>
										<RadioButton Content="Date"
													 GroupName="FilterGroup"
													 Command="{Binding filterGroupSelectedCommand}"
													 CommandParameter="Date"
													 IsChecked="{Binding CurrentSortChoice, Mode=TwoWay, Converter={StaticResource BoolToStrConverter}, ConverterParameter=Date}"
													 Foreground="White"/>
										<RadioButton Content="Size"
													 GroupName="FilterGroup"
													 Command="{Binding filterGroupSelectedCommand}"
													 CommandParameter="Size"
													 IsChecked="{Binding CurrentSortChoice, Mode=TwoWay, Converter={StaticResource BoolToStrConverter}, ConverterParameter=Size}"
													 Foreground="White"/>
										<RadioButton Content="Colour"
													 GroupName="FilterGroup"
													 Command="{Binding filterGroupSelectedCommand}"
													 CommandParameter="Colour"
													 IsChecked="{Binding CurrentSortChoice, Mode=TwoWay, Converter={StaticResource BoolToStrConverter}, ConverterParameter=Colour}"
													 Foreground="White"/>
									</StackPanel>

									<!-- Image Aspect Ratio -->
									<StackPanel Orientation="Horizontal" Spacing="4">
										<RadioButton Content="All"
													 IsChecked="{Binding CurrentAspectRatio, Mode=TwoWay, Converter={StaticResource BoolToStrConverter}, ConverterParameter=All}"
													 GroupName="AspectRatioGroup"
													 Command="{Binding filterAspectRatioCommand}"
													 CommandParameter="All"
													 Foreground="White"/>
										<RadioButton Content="Vertical"
													 IsChecked="{Binding CurrentAspectRatio, Mode=TwoWay, Converter={StaticResource BoolToStrConverter}, ConverterParameter=Vertical}"
													 GroupName="AspectRatioGroup"
													 Command="{Binding filterAspectRatioCommand}"
													 CommandParameter="Vertical"
													 Foreground="White"/>
										<RadioButton Content="4:3"
													 IsChecked="{Binding CurrentAspectRatio, Mode=TwoWay, Converter={StaticResource BoolToStrConverter}, ConverterParameter=4:3}"
													 GroupName="AspectRatioGroup"
													 Command="{Binding filterAspectRatioCommand}"
													 CommandParameter="4:3"
													 Foreground="White"/>
										<RadioButton Content="16:9"
													 IsChecked="{Binding CurrentAspectRatio, Mode=TwoWay, Converter={StaticResource BoolToStrConverter}, ConverterParameter=16:9}"
													 GroupName="AspectRatioGroup"
													 Command="{Binding filterAspectRatioCommand}"
													 CommandParameter="16:9"
													 Foreground="White"/>
										<RadioButton Content="16:10"
													 IsChecked="{Binding CurrentAspectRatio, Mode=TwoWay, Converter={StaticResource BoolToStrConverter}, ConverterParameter=16:10}"
													 GroupName="AspectRatioGroup"
													 Command="{Binding filterAspectRatioCommand}"
													 CommandParameter="16:10"
													 Foreground="White"/>
										<RadioButton Content="21:9"
													 IsChecked="{Binding CurrentAspectRatio, Mode=TwoWay, Converter={StaticResource BoolToStrConverter}, ConverterParameter=21:9}"
													 GroupName="AspectRatioGroup"
													 Command="{Binding filterAspectRatioCommand}"
													 CommandParameter="21:9"
													 Foreground="White"/>
										<RadioButton Content="32:9"
													 IsChecked="{Binding CurrentAspectRatio, Mode=TwoWay, Converter={StaticResource BoolToStrConverter}, ConverterParameter=32:9}"
													 GroupName="AspectRatioGroup"
													 Command="{Binding filterAspectRatioCommand}"
													 CommandParameter="32:9"
													 Foreground="White"/>
									</StackPanel>

								</StackPanel>
							</Border>

						</Popup>


						<Button Grid.Row="1" Command="{Binding navigateToParentDirec}" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4, 6, 0, 0" ToolTip.Tip="Navigate Back">
							<Image Source="avares://Wallmod/Assets/back-icon.png" Width="20" Height="20"></Image>
						</Button>
						
						<Button Grid.Row="2" Command="{Binding selectedDirectory}" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4, 2, 0, 0" ToolTip.Tip="Search Directory">
							<Image Source="avares://Wallmod/Assets/search-folder-icon.png" Width="22" Height="22"></Image>
						</Button>

						<Border Grid.Row="2" Width="14" Height="2" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="15, 44, 0, 0" Background="{Binding SelectedPreviewBackgroundColour, Converter={StaticResource ColorToBrushConverter}}"/>
						
						<Button Grid.Row="2" Command="{Binding uploadClicked}" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5, 54, 0, 0" ToolTip.Tip="Temporarily Add Image To Gallery">
							<Image Source="avares://Wallmod/Assets/addimgicon.png" Width="20" Height="20"></Image>
						</Button>

						
						<Button Grid.Row="3" Background="Transparent" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="4, 0, 0, 44" Command="{Binding viewFavouritesButton}" ToolTip.Tip="View Favourites">
							<Image Source="avares://Wallmod/Assets/favourite-icon.png" Width="20" Height="20"/>
						</Button>
						
						<Button Grid.Row="3" Background="Transparent" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="4, 0, 0, 6" Command="{Binding viewHistoryButton}" ToolTip.Tip="View History">
							<Image Source="avares://Wallmod/Assets/historyicon.png" Width="20" Height="20"/>
						</Button>

						<TextBlock Grid.Row="1" Text="{Binding CurrentSelectedDirecName}" FontSize="17" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0, 6, 0, 0" MaxWidth="260" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />

						<Grid Grid.Row="3" Margin="10" HorizontalAlignment="Right" VerticalAlignment="Bottom">
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="*"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>
							<TextBlock Grid.Row="0" Text="+"  Margin="2, 0, 8, 0" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>
							<Slider Grid.Row="1" x:Name="ThumbnailZoomSlider"
									Orientation="Vertical"
									Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"
									Background="Gray"
									Minimum="50"
									Maximum="300"
									Value="{Binding ThumbnailZoomLevel}"
									HorizontalAlignment="Left"
									Margin="2"
									Width="35" Height="100"
									VerticalAlignment="Center"
									PointerWheelChanged="OnZoomSliderScroll"/>
							<TextBlock Grid.Row="2" Text="-" Margin="2, 0, 9, 0" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>
						</Grid>

						<ScrollViewer Grid.Row="2" x:Name="ImageGalleryScrollView" VerticalScrollBarVisibility="Visible"
									  HorizontalScrollBarVisibility="Disabled" VerticalAlignment="Stretch" Margin="45,12,45,15">

							<Interaction.Behaviors>
								<ia:VerticalScrollViewerAnimatedBehavior/>
							</Interaction.Behaviors>

							<!-- dont add <KeyDown="OnGalleryKeyDown"> since constructor handles it due to func -->
							<ListBox ItemsSource="{Binding DisplayWallpaperList}" x:Name="ImageViewControl" Background="Transparent"
									 SelectionChanged="OnGallerySelectionChanged"  DoubleTapped="OnImageDoubleTapped">
								<ListBox.ItemsPanel>
									<ItemsPanelTemplate>
										<WrapPanel Orientation="Horizontal"/>
									</ItemsPanelTemplate>
								</ListBox.ItemsPanel>
								<ListBox.Styles>
									<Style Selector="ListBoxItem">
										<Setter Property="CornerRadius" Value="10"/>
										<Setter Property="Margin" Value="4"/>
										<Setter Property="Padding" Value="5"/>
									</Style>
								</ListBox.Styles>

								<ListBox.ItemTemplate>
									<DataTemplate>
										<StackPanel Orientation="Vertical" Margin="4">
											<Panel>
												<Image Source="{Binding ImageThumbnailBitmap}"
													   Width="{Binding Value, ElementName=ThumbnailZoomSlider}"/>

												<Border IsVisible="{Binding IsDirectory}"
														CornerRadius="4"
														HorizontalAlignment="Center"
														VerticalAlignment="Bottom"
														Margin="8"
														Padding="4">
													<TextBlock Text="{Binding FolderItemCount}"
															   FontSize="10"
															   Foreground="White"/>
												</Border>
											</Panel>

											<TextBlock
												Text="{Binding Name}"
												TextWrapping="Wrap"
												MaxWidth="100"
												IsVisible="{Binding IsDirectory}"
												HorizontalAlignment="Center" VerticalAlignment="Center"
												Foreground="White" />
										</StackPanel>
									</DataTemplate>
								</ListBox.ItemTemplate>
							
						</ListBox>
						</ScrollViewer>

						<Button Grid.Row="3" HorizontalAlignment="Right" VerticalAlignment="Bottom"
								Background="Transparent" Margin="0,0,3,180" Click="JumpToTopClicked" ToolTip.Tip="Jump To Top">
							<Image Source="avares://Wallmod/Assets/jumptotop-icon.png" Width="20" Height="20"/>
						</Button>

						<Button Grid.Row="3" HorizontalAlignment="Right" VerticalAlignment="Bottom"
								Background="Transparent" Margin="0,0,3,150" Click="JumpToBottomClicked" ToolTip.Tip="Jump To Bottom">
							<Image Source="avares://Wallmod/Assets/jumptobot-icon.png" Width="20" Height="20"/>
						</Button>


					</Grid>

					<!-- History Section -->
					<Grid IsVisible="{Binding IsHistoryViewVisible}" Background="Transparent">
						<views:HistoryView />
					</Grid>

				</Panel>
			</Border>

			<!-- GridSplitter: Allows Resizing Between Left and Right Sections ========= -->
			<GridSplitter x:Name="MainVertSplitter" Grid.Column="1" Grid.Row="0" Grid.RowSpan="1" Width="5"
						  Background="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}" Margin="0,25,0,25"
						  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
						  ShowsPreview="False" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
						  DragStarted="GridSplitterDragExec" />

			<!-- Right Section: Preview and Controls ============================================================ -->
			<Border Grid.Column="2" Grid.Row="0" Background="{Binding SelectedPreviewBackgroundColour, Converter={StaticResource ColorToBrushConverter}}" CornerRadius="10" Margin="8">

				<Grid RowDefinitions="19*,1*" >

					<!--PREVIEW SECTION =========-->
					<ScrollViewer VerticalScrollBarVisibility="Auto" IsVisible="{Binding IsPreviewVisible}">
						<Interaction.Behaviors>
							<ia:VerticalScrollViewerAnimatedBehavior/>
						</Interaction.Behaviors>

						<Grid Margin="18, 6, 18, 0">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>

							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>

							<TextBlock Text="Preview" FontWeight="Bold" FontSize="16"
									   Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
									   Foreground="White" HorizontalAlignment="Center"/>


							<!-- mirror preview horizontally (accent bg = currently mirrored) -->
							<Button Command="{Binding mirrorPreviewCommand}"
									Grid.Row="0" Grid.Column="0"
									HorizontalAlignment="Left"
									Margin="0,0,0,0"
									Background="{Binding MirrorButtonColour, Converter={StaticResource ColorToBrushConverter}}"
									ToolTip.Tip="Mirror Image Horizontally">
								<Image Source="avares://Wallmod/Assets/flip-icon.png" Width="15" Height="15"/>
							</Button>

							<Button Click="EnlargePreviewImg"
									Grid.Row="0" Grid.Column="1"
									HorizontalAlignment="Right"
									Background="Gray" ToolTip.Tip="Enlarge">
								<Image Source="avares://Wallmod/Assets/enlarge-icon.png"
									   Width="14" Height="14"/>
							</Button>

							<!-- monitor preview -->
							<Grid Grid.Row="1" Grid.ColumnSpan="2">
								<Image x:Name="PreviewImage"
									   Source="{Binding CurrentWallpaperPreview}"
									   Stretch="Uniform"
									   IsVisible="True"/>

								<!-- draggable rect -->
								<Canvas x:Name="OverlayCanvas"
										IsHitTestVisible="True"
										Panel.ZIndex="999">
									<Rectangle x:Name="DragRect"
											   StrokeThickness="4"
											   Opacity="0.8"
											   IsVisible="False"
											   Width="100"
											   Height="100"
											   PointerPressed="DragRect_PointerPressed"
											   PointerMoved="DragRect_PointerMoved"
											   PointerReleased="DragRect_PointerReleased">
										<Rectangle.Fill>
											<LinearGradientBrush StartPoint="0,0" EndPoint="200,250">
												<GradientStop Offset="0" Color="rgba(255, 0, 227, 0.27)"/>
												<GradientStop Offset="0.33" Color="rgba(150, 0, 255, 0.27)"/>
												<GradientStop Offset="0.66" Color="rgba(0, 79, 255, 0.27)"/>
												<GradientStop Offset="0.88" Color="rgba(0, 180, 255, 0.27)"/>
												<GradientStop Offset="0.99" Color="rgba(0, 255, 245, 0.27)"/>
											</LinearGradientBrush>
										</Rectangle.Fill>
										<Rectangle.Stroke>
											<LinearGradientBrush StartPoint="0,0" EndPoint="200,200">
												<GradientStop Offset="0.6" Color="White"/>
												<GradientStop Offset="1" Color="Black"/>
											</LinearGradientBrush>
										</Rectangle.Stroke>
									</Rectangle>
									<!-- resize handle indicator: purely visual, sticks to DragRect's bottom-right -->
									<Path x:Name="DragRectHandle"
										  Data="M 0,14 L 14,14 L 14,0 Z"
										  Fill="White"
										  Opacity="0.85"
										  IsHitTestVisible="False"
										  IsVisible="False"/>
								</Canvas>
							</Grid>

							<!-- wallpaper Info -->
							<Grid Grid.Row="2" Grid.ColumnSpan="2">
								<Button Command="{Binding openImageInExplorerCommand}"
										Margin="2" Background="Gray"
										HorizontalAlignment="Left" ToolTip.Tip="Go To Image File">
									<Image Source="avares://Wallmod/Assets/open-icon.png"
										   Width="12" Height="10"/>
								</Button>
								<TextBlock Text="{Binding CurrentWallpaperName}"
										   HorizontalAlignment="Left" FontSize="15"
										   Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}" FontWeight="Bold" Margin="35, 4, 0, 0"
										   MaxWidth="160" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
								<TextBlock Text="{Binding CurrentWallpaperSize}"
										   HorizontalAlignment="Right" FontSize="15"
										   Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}" FontWeight="Bold" Margin="4"/>
							</Grid>


							<!-- monitors row -->
							<Grid Grid.Row="3" Grid.ColumnSpan="2" Margin="0,18,0,8" ColumnDefinitions="Auto,Auto,*,Auto,Auto">

								<TextBlock Grid.Column="0" Text="Monitors:" FontSize="16" Foreground="White"
										   VerticalAlignment="Center" Margin="2,0,0,0"/>

								<!-- refresh monitors (moved here, small, fav-style) -->
								<!-- command AND click, command used for code behind, click used for resetting UI -->
								<Button Grid.Column="1" Command="{Binding #MainWindowAxaml.DetectMonitors}"
										Classes="iconOutline"
										Width="30" Height="30"
										Margin="8,0,0,0"
										VerticalAlignment="Center"
										ToolTip.Tip="Refresh Monitors">
									<Image Source="avares://Wallmod/Assets/refresh-icon.png" Width="13" Height="13"/>
								</Button>

								<!-- One | All toggle (now at the end) -->
								<Border Grid.Column="3" Background="{Binding SelectedWallpaperCollectionColour, Converter={StaticResource ColorToBrushConverter}}" CornerRadius="8" Padding="3"
										Margin="0,0,6,0" VerticalAlignment="Center">
									<StackPanel Orientation="Horizontal" Spacing="0">
										<RadioButton x:Name="SelectOneToggle"
													 Classes="segmented"
													 GroupName="MonitorMode"
													 Content="One"
													 IsThreeState="False"
													 IsChecked="True"
													 Background="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"
													 IsCheckedChanged="OnSelectOneMonitorToggleChecked"/>
										<RadioButton x:Name="SelectAllToggle"
													 Classes="segmented"
													 GroupName="MonitorMode"
													 Content="All"
													 IsThreeState="False"
													 Background="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"
													 IsCheckedChanged="OnSelectAllMonitorsToggleChecked"/>
									</StackPanel>
								</Border>

								<!-- style dropdown -->
								<ComboBox Grid.Column="4"
										  Classes="translucentDark"
										  ItemsSource="{Binding WallpaperStyleList}"
										  SelectedItem="{Binding SelectedWallpaperStyle}"
										  IsEnabled="{Binding StyleDropdownEnabled}"
										  Width="92"
										  FontSize="12"
										  VerticalAlignment="Center"/>
							</Grid>

							<!-- monitor canvas -->
							<Border Grid.Row="4" Grid.ColumnSpan="2" CornerRadius="10"
									BorderBrush="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"
									BorderThickness="1.5">
								<ItemsControl ItemsSource="{Binding MonitorList}">
									<ItemsControl.ItemsPanel>
										<ItemsPanelTemplate>
											<StackPanel Background="Transparent" Width="240" Height="110"/>
										</ItemsPanelTemplate>
									</ItemsControl.ItemsPanel>
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<Canvas>
												<Rectangle Fill="{Binding FillColour}" Width="{Binding UIBounds.Width}" Height="{Binding UIBounds.Height}"
														   Stroke="{Binding StrokeColour}" StrokeThickness="3" Opacity="0.5"
														   Canvas.Left="{Binding UIBounds.X}" Canvas.Top="{Binding UIBounds.Y}"
														   PointerPressed="OnPreviewMonitorTapped"/>
											</Canvas>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</Border>

							<!-- action row: set bg + fav + addToAutoset -->
							<StackPanel Grid.Row="5" Grid.ColumnSpan="2"
										Orientation="Horizontal"
										HorizontalAlignment="Center"
										Spacing="8"
										Margin="0,18,0,12">

								<!-- set background -->
								<Button Name="SetBackgroundButton"
										Content="Set As Background"
										Click="OnSetWallpaperClicked"
										FontWeight="Medium"
										Background="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"
										Width="200" Height="42"
										HorizontalContentAlignment="Center"
										VerticalContentAlignment="Center"
										CornerRadius="8"
										IsEnabled="{Binding SetBackgroundButtonEnabled}"/>

								<!-- fav -->
								<Button x:Name="FavouriteButton"
										Classes="iconOutline"
										Command="{Binding addWallpaperToFavouritesCommand}"
										Width="42" Height="42"
										Background="{Binding FavouriteButtonColour, Converter={StaticResource ColorToBrushConverter}}"
										ToolTip.Tip="Add To Favourites">
									<Image Source="avares://Wallmod/Assets/favourite-icon.png" Width="18" Height="18"/>
								</Button>

								<!-- add to autoset queue -->
								<Button Command="{Binding addWallpaperToAutoSetCommand}"
										Classes="iconOutline"
										Width="42" Height="42"
										Background="{Binding AutoSetButtonColour, Converter={StaticResource ColorToBrushConverter}}"
										ToolTip.Tip="Add To Custom Autoset Queue">
									<Image Source="avares://Wallmod/Assets/addtoqueue-icon.png" Width="18" Height="17"/>
								</Button>
							</StackPanel>

						</Grid>
					</ScrollViewer>

					<!-- bar with buttons -->
					<Grid Grid.Row="1" ColumnDefinitions="*,*">
						<Button Command="{Binding autoSetNavCommand}" CornerRadius="0,0,0,8" ToolTip.Tip="View Autoset Queues"
								MinHeight="30" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
								Background="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}">
							<Image Source="avares://Wallmod/Assets/autoset-icon.png" Width="23" Height="22"/>
						</Button>
						<Button Grid.Column="1" Command="{Binding settingsButton}" CornerRadius="0,0,8,0"
								MinHeight="30" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Gray">
							<Image Source="avares://Wallmod/Assets/settings-icon.png" Width="23" Height="22"/>
						</Button>
						<TextBlock Grid.Column="1"
								   Text="⚠"
								   FontSize="18"
								   FontWeight="Bold"
								   HorizontalAlignment="Center"
								   VerticalAlignment="Center"
								   Margin="48,0,0,0"
								   IsHitTestVisible="False"
								   IsVisible="{Binding UpdateAvailableVisible}"
								   Foreground="{Binding SelectedPrimaryAccentColour, Converter={StaticResource ColorToBrushConverter}}"
								   ToolTip.Tip="Update available"/>
					</Grid>

				</Grid>
			</Border>

			<!-- ========= full-width AutoSet tray (toggled by the blue button via your VM) ========= -->
			<Border Grid.Row="1" Grid.ColumnSpan="3"
					Background="{Binding SelectedPreviewBackgroundColour, Converter={StaticResource ColorToBrushConverter}}"
					CornerRadius="10"
					Margin="8"
					IsVisible="{Binding IsAutoSetVisible}">
				<views:AutoSetView/>
			</Border>

		</Grid>

		<!-- HUGE Image Enlargement Display (covers entire area)-->
		<Image x:Name="EnlargedPreviewImage"
			   Grid.RowSpan="4"
			   Grid.ColumnSpan="4"
			   Source="{Binding CurrentWallpaperPreview}"
			   Stretch="Uniform"
			   IsVisible="False"
			   PointerPressed="OnEnlargedImageClick" />

		<!-- Settings (temp currently put into same vm) -->
		<Grid Name="SettingsGrid" IsVisible="{Binding SettingsViewVisibility}">
			<views:SettingsView />
		</Grid>

	</Panel>

</Window>
